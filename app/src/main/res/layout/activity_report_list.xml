<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ReportListActivity">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reportRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/Mainbtn"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="16dp" />
    <!--tools:listitem="@layout/item_report"-->
    <!--reportRecyclerView에 추가 시 미리보기 달라짐-->

    <Button
        android:id="@+id/Mainbtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="메인화면"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_margin="16dp" />

    <Button
        android:id="@+id/sortlikebtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="공감순"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/Mainbtn"
        app:layout_constraintTop_toTopOf="@id/Mainbtn"
        app:layout_constraintBottom_toBottomOf="@id/Mainbtn" />

    <Button
        android:id="@+id/sortfastbtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="최신순"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/sortlikebtn"
        app:layout_constraintTop_toTopOf="@id/sortlikebtn"
        app:layout_constraintBottom_toBottomOf="@id/sortlikebtn" />

    <Button
        android:id="@+id/itemaddbtn"
        android:layout_width="45dp"
        android:layout_height="50dp"
        android:gravity="center"
        android:text="+"
        android:textSize="24sp"

        android:includeFontPadding="false"
        android:padding="0dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp" />

</androidx.constraintlayout.widget.ConstraintLayout>